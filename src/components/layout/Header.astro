---
import { Image } from "astro:assets";
import Avatars from "../cat/Avatars.astro";
---

<header class="border-b-2 border-theme-light bg-white">
  <div
    class="flex flex-col max-w-page-content mx-auto px-8 py-2 sm:px-12 sm:py-4 sm:flex-row"
  >
    <div class="flex justify-center">
      <a href="/">
        <Image src={"/logo.svg"} alt="logo" width={36} height={36} />
      </a>
      <a href="/">
        <h1
          class="font-handwriting text-theme text-3xl tracking-wider ml-4 translate-y-1"
        >
          Kattenparadijs
        </h1>
      </a>
    </div>
    <Avatars />
  </div>
</header>
