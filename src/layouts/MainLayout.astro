---
import "../styles/global.css";
import { Font } from "astro:assets";
import Header from "../components/layout/Header.astro";
const { title = "Kattenparadijs" } = Astro.props;
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-dancing-script" preload />
    <Font cssVariable="--font-poppins" preload />
    <title>{title}</title>
  </head>
  <body class="font-handwriting">
    <Header />
    <main
      class="max-w-page-content mx-auto py-6 px-8 sm:px-12 sm:py-8 font-handwriting"
    >
      <slot />
    </main>
  </body>
</html>
