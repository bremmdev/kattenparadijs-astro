{
	"compatibility_date": "2026-03-13",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "kattenparadijs-astro",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS",
	},
	"observability": {
		"enabled": true,
	},
	"routes": [
		{
			"pattern": "kattenparadijs-astro.bremmdev.me",
			"custom_domain": true,
		},
	],
}